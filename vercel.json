{
  "rewrites": [
    {"source": "/home", "destination": "/index.html"},
    {"source": "/apply", "destination": "/apply.html"},
    {"source": "/portal", "destination": "/login.html"},
    {"source": "/portal/:path*", "destination": "/login.html"},
    {"source": "/forgot-password", "destination": "/forgot-password.html"},
    {"source": "/academy-management", "destination": "/admin.html"}
  ],
  "redirects": [
    {"source": "/admin.html", "destination": "/academy-management", "permanent": true}
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {"key": "X-Content-Type-Options", "value": "nosniff"},
        {"key": "X-Frame-Options", "value": "DENY"},
        {"key": "Referrer-Policy", "value": "strict-origin-when-cross-origin"}
      ]
    }
  ]
}
